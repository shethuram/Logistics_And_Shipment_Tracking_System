    {
      "name": "5. Driver — Claims & Delivery Flow (real — ravi)",
      "description": "🟡 USE DRIVER TOKEN\nRun '→ Switch to Driver Token' first.\n\nThis is the main demo flow:\nGet Jobs → Claim → Confirm Pickup (senderOtp) → GPS Pings → Confirm Delivery (receiverOtp) → Cash Collected\n\nreceiverOtp: get it from Public Track endpoint (folder 8) after claiming.",
      "item": [
        {
          "name": "Get Available Jobs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/shipments/available",
              "host": ["{{baseUrl}}"],
              "path": ["api","shipments","available"]
            },
            "description": "Shows OPEN shipments eligible for Ravi's TWO_WHEELER. Sorted by distance to pickup. Should show the COD shipment created in folder 4."
          },
          "response": []
        },
        {
          "name": "Claim Shipment",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/shipments/{{shipmentId}}/claim",
              "host": ["{{baseUrl}}"],
              "path": ["api","shipments","{{shipmentId}}","claim"]
            },
            "description": "Claims the shipment. Uses FOR UPDATE SKIP LOCKED — concurrent claims handled. Status → ASSIGNED."
          },
          "response": []
        },
        {
          "name": "Confirm Pickup (enter senderOtp)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp\": \"{{senderOtp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/shipments/{{shipmentId}}/confirm-pickup",
              "host": ["{{baseUrl}}"],
              "path": ["api","shipments","{{shipmentId}}","confirm-pickup"]
            },
            "description": "Uses senderOtp saved from shipment creation. Status → IN_TRANSIT. GPS simulation starts."
          },
          "response": []
        },
        {
          "name": "GPS Ping 1 (near pickup)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipmentId\": \"{{shipmentId}}\",\n  \"latitude\": 11.666000,\n  \"longitude\": 78.148000\n}"
