    {
      "name": "4. Customer — Shipment Booking (real — arjun)",
      "description": "🟢 USE CUSTOMER TOKEN\nRun '→ Switch to Customer Token' first.\n\nAll requests use real Arjun customer.\nCustomer DB id: 9340ef1a-7063-43cf-a9af-2bddf4df6a0a\n\nAfter creating shipment:\n- Copy shipmentId from response\n- Copy senderOtp from response (shown only once!)\n- Note the orderId for public tracking test",
      "item": [
        {
          "name": "Create Shipment — COD (recommended for demo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.id) {",
                  "    pm.collectionVariables.set('shipmentId', json.id);",
                  "    console.log('Shipment ID saved: ' + json.id);",
                  "}",
                  "if (json.orderId) {",
                  "    pm.collectionVariables.set('orderId', json.orderId);",
                  "    console.log('Order ID saved: ' + json.orderId);",
                  "}",
                  "if (json.senderOtp) {",
                  "    pm.collectionVariables.set('senderOtp', json.senderOtp);",
                  "    console.log('SAVE THIS SENDER OTP: ' + json.senderOtp);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pickupAddress\": \"Salem Junction Railway Station, Salem\",\n  \"pickupLat\": 11.664300,\n  \"pickupLng\": 78.146000,\n  \"dropAddress\": \"Big Bazaar, Salem\",\n  \"dropLat\": 11.675000,\n  \"dropLng\": 78.156000,\n  \"receiverName\": \"Priya Sundar\",\n  \"receiverPhone\": \"9988776655\",\n  \"packageType\": \"SMALL_PARCEL\",\n  \"weightKg\": 3.5,\n  \"preferredWindow\": \"EVENING\",\n  \"specialNotes\": \"Please deliver after 5 PM. Leave with security if not home.\",\n  \"paymentMethod\": \"COD\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/shipments",
              "host": ["{{baseUrl}}"],
              "path": ["api","shipments"]
            },
            "description": "COD → status immediately OPEN. shipmentId, orderId, senderOtp auto-saved to variables. NOTE THE SENDER OTP — you need it for confirm-pickup."
          },
          "response": []
        },
        {
          "name": "Get Shipment Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/shipments/{{shipmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api","shipments","{{shipmentId}}"]
            }
          },
          "response": []
        },
        {
