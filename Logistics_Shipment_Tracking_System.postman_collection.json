      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/register/customer", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register", "customer"] },
            "body": { "mode": "raw", "raw": "{\n  \"auth0Id\": \"auth0|customer123\",\n  \"fullName\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"phone\": \"+15551234567\"\n}" }
          }
        },
        {
          "name": "Register Driver",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{driverToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/api/auth/register/driver", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register", "driver"] },
            "body": { "mode": "raw", "raw": "{\n  \"auth0Id\": \"auth0|driver123\",\n  \"fullName\": \"John Smith\",\n  \"email\": \"john.smith@example.com\",\n  \"phone\": \"+15559876543\",\n  \"licenseNumber\": \"DL-123456789\"\n}" }
          }
        },
        {
          "name": "Get Auth0 Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": { "raw": "https://{{auth0Domain}}/oauth/token", "protocol": "https", "host": ["{{auth0Domain}}"], "path": ["oauth", "token"] },
            "body": { "mode": "raw", "raw": "{\n    \"grant_type\": \"password\",\n    \"username\": \"{{username}}\",\n    \"password\": \"{{password}}\",\n    \"audience\": \"{{auth0Audience}}\",\n    \"client_id\": \"{{auth0ClientId}}\",\n    \"client_secret\": \"{{auth0ClientSecret}}\"\n}" }
          }
        }
      ]
    },
    {
